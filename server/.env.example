# ===========================================
# Server Environment Variables (.env)
# ===========================================
# Copy this file to .env and fill in the values

# --- Database ---
DATABASE_URL=postgresql://user:password@host:5432/dbname

# --- Admin Authentication ---
# Credentials used for admin dashboard login
ADMIN_USERNAME=your_admin_email@example.com
ADMIN_PASSWORD=your_secure_password

# --- CORS / Frontend ---
# Production frontend domain (e.g., https://tutuandco.in)
FRONTEND_URL=https://your-production-domain.com

# --- Vercel Blob (Image Storage) ---
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxx

# --- Email Notifications (Resend) ---
# Optional: Leave blank to skip email notifications
RESEND_API_KEY=
RESEND_FROM_EMAIL=Tutu & Co <onboarding@resend.dev>

# --- SMS Notifications (Twilio) ---
# Optional: Leave blank to skip SMS notifications
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- Server ---
PORT=3001
NODE_ENV=development
